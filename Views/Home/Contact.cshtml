@model FinlandCasinoHotels.Models.ContactViewModel
@{
    ViewData["Title"] = "Contact";
    var site = SiteSettingsOptions.Value;
}

<section class="page-header page-header-image" style="background-image: url('/images/hero.jpg');">
    <div class="page-header-overlay"></div>
    <div class="container page-header-content">
        <h1>Contact Us</h1>
        <p>Questions about Dutch casino resorts? Send us a message and we will reply within one business day.</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info-card">
                <h3>Contact Details</h3>

                <div class="contact-detail">
                    <h5>Address</h5>
                    <p>Keizersgracht 482<br />1017 EG Amsterdam, Netherlands</p>
                </div>

                <div class="contact-detail">
                    <h5>Phone</h5>
                    <p>+31 20 555 0147</p>
                </div>

                <div class="contact-detail">
                    <h5>Email</h5>
                    <p>@site.ContactEmail</p>
                </div>

                <div class="contact-detail">
                    <h5>Hours</h5>
                    <p>Monday – Friday: 9:00 – 17:00 CET<br />Saturday – Sunday: Closed</p>
                </div>
            </div>

            <div class="contact-form-card">
                <h3>Send a Message</h3>

                @if (TempData["Success"] != null)
                {
                    <div class="alert-success-custom">
                        Thank you. Your message has been received. We will respond shortly.
                    </div>
                }

                <form asp-action="Contact" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Your name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label"></label>
                        <input asp-for="Subject" class="form-control" placeholder="Resort inquiry" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Message" class="form-label"></label>
                        <textarea asp-for="Message" class="form-control" placeholder="How can we help?"></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
