@{
    ViewData["Title"] = "About";
}

<section class="page-header page-header-image" style="background-image: url('/images/about.jpg');">
    <div class="page-header-overlay"></div>
    <div class="container page-header-content">
        <h1>About Top NL Casino Resorts</h1>
        <p>We help travellers discover the best casino hotel experiences across the Netherlands.</p>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="about-layout">
            <div class="about-image">
                <img src="/images/about.jpg" alt="Dutch casino resort lobby" loading="lazy" />
            </div>
            <div class="content-card">
                <h2>Our Mission</h2>
                <p>
                    Top NL Casino Resorts was built for guests who want more than a gaming floor — they want a full
                    Dutch resort experience. From the historic Kurhaus in Scheveningen to boutique canal hotels in
                    Amsterdam, the Netherlands offers casino stays with character, culture, and comfort.
                </p>
                <p>
                    We curate and present the country's standout casino hotels so you can compare locations,
                    amenities, and atmospheres before you book your next trip.
                </p>
            </div>
        </div>

        <div class="content-card" style="margin-top: 2.5rem;">
            <h2>How We Select Resorts</h2>
            <p>Every property on our site is evaluated against clear criteria:</p>
            <ul>
                <li>Connection to a licensed Holland Casino or KSA-approved gaming venue</li>
                <li>Quality accommodation with well-rated rooms and on-site dining</li>
                <li>Strong location — city centre, seaside, or scenic regional settings</li>
                <li>Professional guest services and transparent resort policies</li>
                <li>Commitment to responsible gaming for guests aged 18 and over</li>
            </ul>

            <h2>What We Offer</h2>
            <p>
                This site provides an overview of selected casino resorts across the Netherlands, including
                Amsterdam, The Hague (Scheveningen), Rotterdam, and Maastricht. We share practical information
                about each property so you can find the right match for your travel style and budget.
            </p>

            <h2>Responsible Gaming</h2>
            <p>
                Gambling should remain entertainment. We encourage all guests to set limits, take regular breaks,
                and use the responsible gaming tools available at every licensed venue. In the Netherlands,
                self-exclusion is managed through Cruks (Centraal Register Uitsluiting Kansspelen). Casino access
                is restricted to adults aged 18 and over.
            </p>
        </div>
    </div>
</section>
